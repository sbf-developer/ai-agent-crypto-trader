# Server
PORT=4173
HOST=127.0.0.1
NODE_ENV=development
PUBLIC_APP_ORIGIN=http://localhost:4173

# Wallet login uses a one-time EVM signature challenge. No password or seed phrase is stored by Vector.
SESSION_TTL_MS=28800000

# Public market feed used by the dashboard. Binance USDⓈ-M Futures is the default venue.
MARKET_API_BASE=https://fapi.binance.com
MARKET_WS_BASE=wss://fstream.binance.com/ws

# Execution is fail-closed. Set TRADING_MODE=live and LIVE_TRADING_ACK=YES only after review.
TRADING_MODE=disabled
LIVE_TRADING_ACK=NO
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://fapi.binance.com
BINANCE_RECV_WINDOW=5000

# Optional AI decision provider. The key stays server-side and is never sent to the browser.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
AI_AUTO_EXECUTE=false
AI_SHARE_ACCOUNT_DATA=false

# Initial hard limits. The UI may only tighten these at runtime.
ALLOWED_SYMBOLS=BTCUSDT,ETHUSDT
MAX_LEVERAGE=3
MAX_NOTIONAL_USDT=1000
MAX_RISK_PCT=1
MAX_DAILY_LOSS_USDT=100
MIN_AI_CONFIDENCE=0.72
